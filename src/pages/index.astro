---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import PostCard from "@/components/PostCard.astro";
import Newsletter from "@/components/Newsletter.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { slugifyStr } from "@/utils/slugify";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const gridPosts = sortedPosts.slice(0, postsConfig.perIndex);
const homePath = getRelativeLocaleUrl(locale, "");

// Chip row: the most-recently-seen tags across all posts (not just the ones
// shown below), capped so the row doesn't wrap onto three lines.
const topTags = [
  ...new Set(sortedPosts.flatMap(({ data }) => data.tags ?? [])),
].slice(0, 6);
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-8 pb-6">
      <p class="text-foreground/80 max-w-prose text-justify text-[15px] hyphens-auto">
        Sou estudante na Universidade de Brasília (UnB) e atualmente trabalho na
        SIGNA. Por aqui, escrevo sobre o que venho aprendendo e explorando pelo
        caminho.
      </p>
      <div class="mt-4 flex flex-wrap items-center gap-4">
        <a
          href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
          target="_blank"
          class="text-muted-foreground hover:text-accent inline-flex items-center gap-1.5 text-sm"
          aria-label="RSS Feed"
        >
          <IconRss width={16} height={16} class="stroke-current rtl:-rotate-90" />
          RSS
        </a>
        {socials.length > 0 && <Socials />}
      </div>
    </section>

    {
      topTags.length > 0 && (
        <ul class="flex flex-wrap gap-2 py-6">
          <li>
            <span class="tag-accent">Tudo</span>
          </li>
          {topTags.map(tag => (
            <li>
              <a
                href={getRelativeLocaleUrl(locale, `tags/${slugifyStr(tag)}/`)}
                class="tag-neutral hover:opacity-80"
              >
                {tag}
              </a>
            </li>
          ))}
        </ul>
      )
    }

    {
      gridPosts.length > 0 && (
        <ul class="border-border grid grid-cols-1 gap-x-6 gap-y-10 border-t pt-8 sm:grid-cols-2">
          {gridPosts.map(post => (
            <PostCard {...post} />
          ))}
        </ul>
      )
    }

    <div class="my-10 text-center">
      <a href={getRelativeLocaleUrl(locale, "posts")} class="btn-ghost">
        Posts mais antigos
      </a>
    </div>

    <Newsletter />
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
