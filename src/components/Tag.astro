---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
  variant?: "accent" | "neutral" | "outline";
};

const { tag, tagName, size = "lg", variant = "neutral" } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;

const variantClass = {
  accent: "tag-accent",
  neutral: "tag-neutral",
  outline: "tag-outline",
}[variant];
---

<li class="inline-flex">
  <a
    href={getRelativeLocaleUrl(locale, `tags/${tag}/`)}
    transition:name={tag}
    class:list={[
      variantClass,
      "hover:opacity-80",
      { "text-[11px]! py-0.5!": size === "sm" },
    ]}
  >
    {tagName}
  </a>
</li>
