---
import IconRss from "@/assets/icons/IconRss.svg";
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
---

<section class="border-border border-t py-10 text-center">
  <span class="text-accent text-[11px] font-medium tracking-wide uppercase">
    Sem pressa, sem spam
  </span>
  <h2 class="mt-3 text-2xl font-normal text-balance sm:text-3xl">
    Um aviso quando sair post novo.
  </h2>
  <p class="text-foreground/80 mx-auto mt-3 max-w-sm text-sm">
    Nada de disparo toda semana — só um e-mail curto quando eu publicar algo.
    Cancele quando quiser.
  </p>
  <form class="mx-auto mt-5 flex max-w-sm gap-2">
    <label class="flex-1">
      <span class="sr-only">Seu e-mail</span>
      <input
        type="email"
        placeholder="seu@email.com"
        disabled
        class="border-border placeholder:text-muted-foreground w-full rounded-md border bg-transparent px-3 py-2 text-sm disabled:cursor-not-allowed disabled:opacity-70"
      />
    </label>
    <button type="button" disabled class="btn-primary shrink-0 opacity-70">
      Quero
    </button>
  </form>
  <p class="text-muted-foreground mt-3 text-xs">
    Em breve por aqui ·{" "}
    <a
      href={`${getRelativeLocaleUrl(locale, "")}rss.xml`}
      target="_blank"
      class="text-accent-strong inline-flex items-center gap-1 hover:underline"
    >
      <IconRss class="size-3.5" /> o RSS já funciona
    </a>
  </p>
</section>
