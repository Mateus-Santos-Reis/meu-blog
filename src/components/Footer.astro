---
import type { HTMLAttributes } from "astro/types";
import { getRelativeLocaleUrl } from "astro:i18n";
import Socials from "./Socials.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const t = useTranslations(Astro.currentLocale);
const locale = Astro.currentLocale ?? config.site.lang;
const currentYear = new Date().getFullYear();
const { site, features } = config;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div class="border-border grid grid-cols-2 gap-8 border-t pt-8 pb-6 sm:grid-cols-3">
    <div class="col-span-2 sm:col-span-1">
      <p class="font-heading text-lg">{site.title}</p>
      <p class="text-muted-foreground mt-2 max-w-[22ch] text-sm">
        {site.description}
      </p>
    </div>
    <div class="flex flex-col gap-2 text-sm">
      <span class="text-accent text-[11px] font-medium tracking-wide uppercase">
        Ler
      </span>
      <a href={getRelativeLocaleUrl(locale, "posts")} class="hover:text-accent w-fit">
        Todos os posts
      </a>
      {
        features.showArchives && (
          <a
            href={getRelativeLocaleUrl(locale, "archives")}
            class="hover:text-accent w-fit"
          >
            Arquivo por ano
          </a>
        )
      }
      <a href={getRelativeLocaleUrl(locale, "about")} class="hover:text-accent w-fit">
        Sobre mim
      </a>
    </div>
    <div class="flex flex-col gap-2 text-sm">
      <span class="text-accent text-[11px] font-medium tracking-wide uppercase">
        Achar
      </span>
      <Socials />
    </div>
  </div>
  <div
    class="border-border flex flex-col items-center justify-between gap-2 border-t py-4 text-sm sm:flex-row"
  >
    <p class="font-heading text-accent-strong italic">— {site.title}</p>
    <div class="text-muted-foreground flex flex-col items-center whitespace-nowrap sm:flex-row">
      <span>{t.footer.copyright} &#169; {currentYear}</span>
      <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
      <span>{t.footer.allRightsReserved}</span>
    </div>
  </div>
</footer>
